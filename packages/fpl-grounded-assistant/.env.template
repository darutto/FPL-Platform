# FPL Grounded Assistant — environment template
# Copy this file to .env and fill in your keys.
# .env is gitignored. This template is safe to commit.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# Which LLM to use for response presentation.
# Allowed values: gemini | anthropic | openai
# Default when unset: gemini
DEFAULT_PROVIDER=gemini

# ---------------------------------------------------------------------------
# Architectural pivot rollout flags
# ---------------------------------------------------------------------------
# Required: enable orchestrator-primary routing for plain-text queries.
FPL_ORCH_ENABLED=1

# Recommended for the initial Patreon launch: disable session endpoints until
# session turns surface token usage instead of recording tokens=0.
FPL_SESSION_ENABLED=false

# ---------------------------------------------------------------------------
# Provider API keys
# Only the key for the active DEFAULT_PROVIDER is required at runtime.
# The others are read but ignored unless DEFAULT_PROVIDER is toggled.
# ---------------------------------------------------------------------------

# Google Gemini (default provider)
GOOGLE_API_KEY=your_google_api_key_here 

# Anthropic Claude (set DEFAULT_PROVIDER=anthropic to activate)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT (set DEFAULT_PROVIDER=openai to activate)
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------------------------
# Security / feature flags
# ---------------------------------------------------------------------------

# Optional: shared secret for GET /quota endpoint (set in production to prevent quota probing)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Send via request header: X-Internal-Token: <value>
FPL_INTERNAL_TOKEN=
