# FPL Grounded Assistant backend URL.
# For local dev: run `python fpl_server.py` in packages/fpl-grounded-assistant
# and set this to the server address (default: http://localhost:8000).
# For Railway: set this to your deployed Railway service URL.
FPL_BACKEND_URL=http://localhost:8000

# World Cup assistant backend URL.
# For local dev: run `python -m uvicorn worldcup_assistant.wc_server:app --port 8100`
# in packages/worldcup-assistant (default: http://localhost:8100).
# For Railway: set this to its own deployed Railway service URL.
WC_BACKEND_URL=http://localhost:8100

# Clerk authentication (Phase 3 — Patreon-gated access).
# Get these from Clerk dashboard -> Configure -> API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx

# Clerk custom OAuth provider key for Patreon (set when configuring the
# SSO connection in Clerk -> Configure -> SSO connections -> Patreon).
# Format: oauth_custom_<key>, e.g. oauth_custom_patreon
NEXT_PUBLIC_CLERK_PATREON_STRATEGY=oauth_custom_patreon

# Comma-separated emails that always get subscriber-tier access, bypassing
# the Patreon membership check (e.g. the page owner, who isn't a patron of
# their own page). Never exposed to the browser.
ADMIN_EMAILS=
