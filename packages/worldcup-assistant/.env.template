# worldcup-assistant — separate Railway service env (do not share with FPL)

# Data source: FIFA Fantasy public feed (play.fifa.com/json/fantasy/) — free,
# no API key required. worldcupapi.com is no longer used (trials disabled
# until WC2026 ends).

# Knockout bracket source: openfootball public-domain JSON (free, no key).
# The FIFA Fantasy feed has no knockout fixtures, so get_bracket reads this
# file instead. Updated by hand ~once/day upstream; the client re-pulls it a
# few times a day via a 6 h in-process TTL. Override only to pin a tag/mirror.
# WORLDCUP_JSON_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# Optional: API-Football (api-football.com) — adds match-level stats not in
# the FIFA Fantasy feed (cards, minutes played, saves, etc.). Free tier:
# 100 req/day, 10 req/min. Leave blank to skip this enrichment entirely.
API_FOOTBALL_KEY=

# Optional: BallDontLie FIFA World Cup API (balldontlie.io) — paid (GOAT tier
# $39.99/mo), covers WC 2018/2022/2026 incl. live 2026: minutes, cards,
# saves, tackles/interceptions/clearances, big chances created/missed, xG/xA.
# Leave blank to skip this enrichment entirely.
BALLDONTLIE_API_KEY=

# LLM provider (orchestrator-primary)
# Allowed values: gemini | anthropic | openai
# Hybrid model architecture: the orchestrator is the gatekeeper for tool
# selection, negative-constraint adherence, and web-search query construction.
# It runs on a high-tier Pro model — a small model (e.g. 2.5-flash) over-calls
# web_search and passes raw conversational sentences as queries. Provider token
# is "gemini" (NOT "google"; the stack matches on "gemini").
WC_PROVIDER=gemini
WC_ORCH_MODEL=gemini-2.5-pro
GOOGLE_API_KEY=

# Only needed if WC_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Premium web search (Tavily — search API for LLM agents). Required for the
# gated web_search tool; leave blank to disable web search entirely.
TAVILY_API_KEY=

# Default tier when no X-User-Tier header is present (Clerk supplies the real
# value in prod). Set to patreon_basic / patreon_premium locally to exercise
# the premium web-search path. Defaults to "free" (web search gated off).
WC_DEV_TIER=free

# Optional tuning
# WC_MAX_ITERATIONS=4
# WC_MAX_TOKENS=1024
# WC_TIMEOUT_S=30
# WC_PORT=8100

# ---------------------------------------------------------------------------
# Quota persistence
# ---------------------------------------------------------------------------
# Redis connection string for the per-user quota store (worldcup_assistant/quota.py).
# Required in production — without it, quota counters live in an in-memory
# dict and are wiped on every restart/redeploy. Railway: add a Redis plugin
# and it auto-injects this var. Leave blank for local dev (falls back to
# in-memory, fine for testing).
REDIS_URL=
